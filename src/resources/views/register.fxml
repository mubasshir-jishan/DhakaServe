<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<StackPane fx:controller="com.myapp.controllers.RegisterController"
           styleClass="root-pane"
           stylesheets="@register.css"
           xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1">

    <VBox alignment="CENTER" maxWidth="450">
        <VBox alignment="CENTER" styleClass="register-panel" spacing="15">
            <padding>
                <Insets top="30" right="50" bottom="30" left="50" />
            </padding>

            <!-- Logo Icon -->
            <ImageView fitHeight="90.0" fitWidth="90.0" pickOnBounds="true" preserveRatio="true" styleClass="logo-icon">
                <Image url="@../../assets/logo_icon.png" />
            </ImageView>

            <!-- Logo Text -->
            <VBox alignment="CENTER" spacing="5" styleClass="logo-text-container">
                <TextFlow textAlignment="CENTER">
                    <Text text="DHAKA" styleClass="logo-text-dhaka" />
                    <Text text="SERVE" styleClass="logo-text-serve" />
                </TextFlow>
                <Text text="— A PROFESSIONAL &amp; CORPORATE SERVICE PLATFORM —" styleClass="logo-subtitle" />
            </VBox>

            <!-- Header -->
            <Text text="Create Your Account" styleClass="header-text" />

            <!-- Form Fields -->
            <VBox spacing="15">
                <TextField fx:id="nameField" promptText="Full Name" styleClass="input-field" />
                <TextField fx:id="emailField" promptText="Email Address" styleClass="input-field" />
                <PasswordField fx:id="passField" promptText="Password" styleClass="input-field" />
                <ChoiceBox fx:id="typeChoice" maxWidth="Infinity" styleClass="input-field" />
            </VBox>

            <!-- Actions -->
            <VBox alignment="CENTER" spacing="15">
                <Button text="Create Account" onAction="#handleSubmit" styleClass="register-button" maxWidth="Infinity"/>
                <Hyperlink text="Already have an account? Login" onAction="#goToLogin" styleClass="login-link" />
            </VBox>
        </VBox>
    </VBox>
</StackPane>