<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="450.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #e8f4f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.myapp.controllers.PaymentController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label text="Complete Your Payment">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>
    <VBox spacing="5.0" style="-fx-border-color: #b0c4de; -fx-padding: 10; -fx-border-radius: 5;">
        <Label fx:id="serviceTitleLabel" text="Service: Title of the Gig">
            <font><Font size="14.0" /></font>
        </Label>
        <Label fx:id="totalAmountLabel" text="Total Amount: ৳0.00">
            <font><Font name="System Bold" size="16.0" /></font>
        </Label>
        <Label fx:id="feeLabel" text="Includes 10% Platform Fee: ৳0.00">
            <font><Font size="12.0" /></font>
        </Label>
    </VBox>
    <Label text="Select Payment Method" />
    <HBox alignment="CENTER" spacing="20.0">
        <fx:define>
            <ToggleGroup fx:id="paymentMethodGroup" />
        </fx:define>
        <RadioButton fx:id="bkashRadio" text="bKash" toggleGroup="$paymentMethodGroup" selected="true" />
        <RadioButton fx:id="nogadRadio" text="Nogad" toggleGroup="$paymentMethodGroup" />
        <RadioButton fx:id="cardRadio" text="Card" toggleGroup="$paymentMethodGroup" />
    </HBox>
    <VBox fx:id="paymentDetailsBox" spacing="10.0" alignment="CENTER">
        <Label fx:id="paymentInstructionLabel" text="Enter your bKash Transaction ID" />
        <TextField fx:id="paymentField" promptText="e.g., ABC123XYZ" />
    </VBox>
    <Button onAction="#handlePayNow" style="-fx-background-color: #28a745; -fx-text-fill: white;" text="Pay Now" />
    <Button onAction="#goBack" text="Cancel" />
</VBox>
