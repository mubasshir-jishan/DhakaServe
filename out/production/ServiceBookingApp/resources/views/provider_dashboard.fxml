<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.util.Callback?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="950.0" stylesheets="@provider-dashboard.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.myapp.controllers.ProviderDashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" styleClass="header-box" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Label fx:id="welcomeLabel" styleClass="header-label" text="Welcome, Provider!" HBox.hgrow="ALWAYS">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" onAction="#goToEarnings" styleClass="header-button" text="My Earnings" />
                <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="header-button-logout" text="Logout" />
            </children>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.45" orientation="VERTICAL" prefHeight="200.0" prefWidth="160.0" BorderPane.alignment="CENTER">
            <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
                    <children>
                        <VBox layoutX="14.0" layoutY="14.0" spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="section-header" text="My Gigs" HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#goToAddGig" styleClass="action-button-add" text="+ Add Gig" />
                                        <Button mnemonicParsing="false" onAction="#goToEditGig" styleClass="action-button-edit" text="Edit Selected" />
                                        <Button mnemonicParsing="false" onAction="#handleDeleteGig" styleClass="action-button-delete" text="Delete Selected" />
                                    </children>
                                </HBox>
                                <TableView fx:id="gigsTableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="gigTitleColumn" prefWidth="250.0" text="Title" />
                                        <TableColumn fx:id="gigCategoryColumn" prefWidth="150.0" text="Category" />
                                        <TableColumn fx:id="gigPriceColumn" prefWidth="100.0" text="Price (৳)" />
                                        <TableColumn fx:id="gigRatingColumn" prefWidth="100.0" text="Rating" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
                    <children>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                            <children>
                                <Label styleClass="section-header" text="Incoming Bookings" />
                                <TableView fx:id="bookingsTableView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="serviceColumn" prefWidth="175.0" text="Service" />
                                        <TableColumn fx:id="customerColumn" prefWidth="150.0" text="Customer" />
                                        <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Status" />
                                        <TableColumn fx:id="paymentColumn" prefWidth="110.0" text="Payment" />
                                        <TableColumn fx:id="actionsColumn" prefWidth="250.0" text="Actions" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </center>
</BorderPane>
